# === Database ===
DATABASE_URL=postgresql://chatbot_user:chatbot_pass@db:5432/chatbot_db

# === JWT ===
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_me_to_a_random_32_byte_hex_string_please_do_it_now
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Audit Log Hash Chain ===
# The genesis hash seed - used only for the very first log entry
AUDIT_GENESIS_SEED=genesis_block_seed_change_in_production

# === AI Provider ===
# Options: openai, ollama, mock
AI_PROVIDER=mock
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# === Server ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=30
