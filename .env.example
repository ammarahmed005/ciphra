# Docker Compose environment variables.
# Copy this file to .env in the same directory as docker-compose.yml and edit.

# === REQUIRED: change these for production ===
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_me_to_a_random_32_byte_hex_string
AUDIT_GENESIS_SEED=change_me_to_a_random_string

# === AI Provider ===
# Options:
#   mock   - no external calls, canned responses (default, works offline)
#   openai - uses OpenAI Chat Completions API
#   ollama - uses a local Ollama server
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
